# ------------------------------------------------------------------
#  App
# ------------------------------------------------------------------
# URL pública do app (usada em OAuth, webhooks e no manifest do PWA).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------------------------------------------
#  Banco de dados (Postgres do Supabase — aba Project Settings > Database)
# ------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# ------------------------------------------------------------------
#  Supabase Auth (aba Project Settings > API)
# ------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ------------------------------------------------------------------
#  OpenAI (roteiros, criativos e pesquisa)
# ------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=gpt-image-1

# ------------------------------------------------------------------
#  Instagram (API with Instagram Login — login direto pelo Instagram)
#  App em developers.facebook.com → produto "Instagram" → API setup with Instagram login.
#  Use o Instagram App ID/Secret (NÃO o do Facebook). Conta precisa ser Business/Creator.
#  Callback OAuth: <APP_URL>/api/meta/connect/callback   Webhook: <APP_URL>/api/meta/webhook
# ------------------------------------------------------------------
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
META_VERIFY_TOKEN=
META_GRAPH_VERSION=v23.0
# Legado (fallback): usados se INSTAGRAM_APP_ID/SECRET não estiverem definidos
META_APP_ID=
META_APP_SECRET=
# Legado (fallback de conta única; a integração multi-conta usa tokens por conta no banco)
META_ACCESS_TOKEN=
META_IG_USER_ID=
META_WORKSPACE_ID=

# ------------------------------------------------------------------
#  Publicação agendada (Vercel Cron chama /api/cron/publish)
# ------------------------------------------------------------------
CRON_SECRET=
